#!/bin/sh
# Pre-push hook: block push if any of these fail:
#   - Security (gitleaks + Semgrep + osv-scanner — see docs/SECURITY.md)
#   - Build (tsc / compile)
#   - Lint (--max-warnings ratcheted)
#   - Format check (Prettier)
#   - Tests + coverage (per docs/DoD.md §3)
#   - IaC validate (cdk synth / terraform / helm — see docs/INFRASTRUCTURE.md)
#   - Project-specific guards (see .githooks/pre-push-project)
#
# This file is tracked in the repo at .githooks/pre-push. New clones pick it
# up automatically via the `postinstall` script in your project's package.json,
# which runs `git config --local core.hooksPath .githooks`.
#
# This is the BLUEPRINT version: generic checks only. Project-specific guards
# (placeholder injection, asset invariants, release-notes guard, etc.) live
# in .githooks/pre-push-project and are sourced below if present.

set -e

echo "🔒 Pre-push: security + build + lint + tests..."

# --- Security: gitleaks + Semgrep + osv-scanner (docs/SECURITY.md cross-recipe rules) ---
# All three are skipped with a warning if the binary isn't installed locally
# — CI re-runs them as a backstop. This keeps a fresh clone from being
# blocked on day 1 while still nudging the developer to install them.

if command -v gitleaks >/dev/null 2>&1; then
  echo "  → Secret scan (gitleaks)..."
  gitleaks protect --staged --redact --no-banner || {
    echo "❌ gitleaks found a secret in staged changes."
    echo "   Unstage + rotate the credential. A leaked secret is compromised the"
    echo "   moment it lands on origin; rotating is non-negotiable."
    exit 1
  }
else
  echo "  ⚠ gitleaks not installed locally — secret scan skipped (CI will catch it)."
  echo "     Install: brew bundle  (from repo root, uses ./Brewfile)"
fi

if command -v semgrep >/dev/null 2>&1; then
  echo "  → SAST (semgrep p/owasp-top-ten)..."
  # Bundled rulesets (no network call). p/owasp-top-ten is the conservative
  # baseline; projects can add more packs in .githooks/pre-push-project.
  # Explicit --severity flags rather than --error — some packs flag INFO,
  # which we don't want blocking pre-push.
  semgrep \
    --config=p/owasp-top-ten \
    --severity=WARNING \
    --severity=ERROR \
    --error \
    --quiet \
    --timeout=20 \
    --metrics=off \
    . || {
    echo "❌ Semgrep found a WARNING+ finding."
    echo "   Fix the finding, or suppress with '// nosemgrep: <rule-id> — <justification>'"
    echo "   naming the threat-model entry in project_config_security.md that makes it safe."
    exit 1
  }
else
  echo "  ⚠ semgrep not installed locally — SAST skipped (CI will catch it)."
  echo "     Install: brew bundle  (from repo root, uses ./Brewfile)"
fi

if command -v osv-scanner >/dev/null 2>&1; then
  echo "  → SCA (osv-scanner over lockfiles)..."
  # Scan every lockfile in the repo; the tool no-ops on workspaces that lack one.
  osv-scanner --recursive --skip-git --fail-on-vuln . >/dev/null 2>&1 || {
    echo "❌ osv-scanner found a HIGH+ CVE in a dependency."
    echo "   Upgrade or pin to a known-good version. Track lower-severity CVEs"
    echo "   in docs/config/findings.md with a planned upgrade date."
    exit 1
  }
else
  echo "  ⚠ osv-scanner not installed locally — SCA skipped (CI will catch it)."
  echo "     Install: brew bundle  (from repo root, uses ./Brewfile)"
fi

# Adjust these paths / commands to match your project's workspaces.
# {{PROJECT_NAME}}: edit this block during bootstrap to reflect your layout.

# Each workspace runs the same gate order (per docs/DoD.md §4):
#   build → lint → format:check → test:coverage → project guards
#
# Required npm scripts per workspace:
#   - build         (e.g. tsc)
#   - lint          (eslint with ratcheted --max-warnings)
#   - format:check  (prettier --check . — fails if anything unformatted)
#   - test:coverage (test runner + coverage; fails if project's
#                    greenfield ≥90% / brownfield ≥70% threshold not met,
#                    per project_config_dod.md)

# --- Backend (if present) ---
if [ -d backend ]; then
  echo "  → Backend build..."
  ( cd backend && npm run build ) || { echo "❌ Backend build failed."; exit 1; }

  echo "  → Backend lint..."
  ( cd backend && npm run lint ) || { echo "❌ Backend lint exceeded --max-warnings threshold."; exit 1; }

  echo "  → Backend format check (Prettier)..."
  ( cd backend && npm run format:check ) || { echo "❌ Backend has unformatted files. Run 'npm run format' in backend/ and recommit."; exit 1; }

  echo "  → Backend tests + coverage..."
  ( cd backend && npm run test:coverage ) || { echo "❌ Backend tests failed or coverage below threshold (see project_config_dod.md)."; exit 1; }
fi

# --- Frontend (if present) ---
if [ -d frontend ]; then
  echo "  → Frontend lint..."
  ( cd frontend && npm run lint ) || { echo "❌ Frontend lint exceeded --max-warnings threshold."; exit 1; }

  echo "  → Frontend format check (Prettier)..."
  ( cd frontend && npm run format:check ) || { echo "❌ Frontend has unformatted files. Run 'npm run format' in frontend/ and recommit."; exit 1; }

  echo "  → Frontend tests + coverage..."
  ( cd frontend && npm run test:coverage ) || { echo "❌ Frontend tests failed or coverage below threshold (see project_config_dod.md)."; exit 1; }
fi

# --- IaC validate: cdk synth / terraform validate / helm lint (docs/INFRASTRUCTURE.md cross-recipe rules) ---
# Each step runs only if the corresponding infra layout is present and the
# tool is installed. Missing tool prints a hint and skips — CI re-runs as
# the backstop. Same UX pattern as the security gate above.

if [ -d infra ]; then
  # Recipe A — CDK (TypeScript): detect by infra/cdk.json
  if [ -f infra/cdk.json ]; then
    if command -v cdk >/dev/null 2>&1; then
      echo "  → IaC synth (cdk)..."
      ( cd infra && cdk synth --quiet >/dev/null ) || {
        echo "❌ cdk synth failed. Fix the IaC errors before pushing."
        echo "   Run 'cd infra && cdk synth' locally to see the full output."
        exit 1
      }
    else
      echo "  ⚠ cdk not installed locally — IaC synth skipped (CI will catch it)."
      echo "     Install: brew bundle  (from repo root, uses ./Brewfile)"
    fi
  fi

  # Recipe B — Terraform: detect by any infra/**/*.tf
  if ls infra/**/*.tf >/dev/null 2>&1 || ls infra/*.tf >/dev/null 2>&1; then
    if command -v terraform >/dev/null 2>&1; then
      echo "  → IaC validate (terraform)..."
      ( cd infra && terraform fmt -check -recursive >/dev/null ) || {
        echo "❌ Terraform files are unformatted. Run 'terraform fmt -recursive' in infra/ and recommit."
        exit 1
      }
      # terraform validate needs init; skip if .terraform/ isn't present (CI does the deeper validate)
      if [ -d infra/.terraform ]; then
        ( cd infra && terraform validate >/dev/null ) || {
          echo "❌ terraform validate failed. Fix the IaC errors before pushing."
          exit 1
        }
      else
        echo "    (skipping terraform validate — run 'terraform init' in infra/ to enable locally)"
      fi
    else
      echo "  ⚠ terraform not installed locally — IaC validate skipped (CI will catch it)."
      echo "     Install: brew bundle  (from repo root, uses ./Brewfile)"
    fi
  fi

  # Recipe C — Helm charts: detect by infra/charts/*/Chart.yaml
  if ls infra/charts/*/Chart.yaml >/dev/null 2>&1; then
    if command -v helm >/dev/null 2>&1; then
      echo "  → IaC lint (helm)..."
      for chart in infra/charts/*/; do
        helm lint "$chart" >/dev/null || {
          echo "❌ helm lint failed on $chart"
          exit 1
        }
      done
    else
      echo "  ⚠ helm not installed locally — chart lint skipped (CI will catch it)."
      echo "     Install: brew bundle  (from repo root, uses ./Brewfile)"
    fi
  fi
fi

# --- .claude/settings.json host-path guard (generic struct2flow rule) ---
# The COMMITTED settings.json must be host-agnostic — it travels with the
# repo to every machine and (when public) every fork. Absolute paths to a
# specific machine's home directory leak via Claude Code's auto-allowlist
# every time the agent runs a Bash command with such a path. They belong
# in .claude/settings.local.json (gitignored), never in settings.json.
#
# Three drift cycles in a row landed paths like /Users/<name>/.ssh,
# /Users/<name>/sources/, /Users/<name>/Library/Containers/... in
# settings.json. This guard blocks any future occurrence.
#
# To allow-list a legitimate generic path that happens to contain /Users
# or /home as a literal substring (rare), add a comment line above the
# entry: this grep is line-based and won't match across lines.
echo "  → .claude/settings.json host-path guard..."
if [ -f .claude/settings.json ]; then
  HOST_PATHS=$(grep -nE '/(Users|home)/[A-Za-z0-9_.-]+/' .claude/settings.json || true)
  if [ -n "$HOST_PATHS" ]; then
    echo "❌ .claude/settings.json contains host-specific paths."
    echo "   Move them to .claude/settings.local.json (gitignored) — settings.json"
    echo "   is committed and must stay host-agnostic."
    echo "$HOST_PATHS" | sed 's/^/     /'
    exit 1
  fi
fi

# --- Project-specific guards (sourced if present) ---
# Add your project's invariants in .githooks/pre-push-project:
#   - placeholder / config drift guards
#   - asset / favicon / head-block invariants
#   - release-notes guard
#   - localization parity checks
# This keeps .githooks/pre-push pristine (blueprint-managed) and lets the
# blueprint sync forward without trampling your project guards.
if [ -f .githooks/pre-push-project ]; then
  echo "  → Project-specific guards..."
  . .githooks/pre-push-project
fi

echo "✅ All checks passed. Pushing..."
