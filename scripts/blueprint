#!/usr/bin/env bash
#
# blueprint — sync CLI for struct2flow projects.
#
# Subcommands:
#   blueprint drift             Show which blueprint-managed files in this project
#                               have drifted from the blueprint HEAD, and what's
#                               changed in the blueprint since this project was
#                               last synced.
#   blueprint pull [FILE...]    Pull blueprint-managed files forward into this
#                               project. Interactive per file unless --yes.
#                               With no FILE, pulls every file that's drifted.
#   blueprint a2bp FILE [...]   Apply-to-blueprint: copy this project's version
#                               of FILE(s) BACK to the blueprint working tree as
#                               a staged change. You then review + commit + push
#                               in the blueprint repo yourself.
#   blueprint files             List the blueprint-managed files (source of truth).
#   blueprint help              This message.
#
# The "blueprint" location is read from .blueprint-source in the current
# project (created by new-project.sh on bootstrap). All commands except
# `files` and `help` must run from inside a struct2flow project.
#
# Add this directory to PATH so the command is callable as `blueprint`:
#   export PATH="$HOME/sources/struct2flow/blueprint/scripts:$PATH"
# Or symlink it:
#   ln -s ~/sources/struct2flow/blueprint/scripts/blueprint /usr/local/bin/blueprint

set -euo pipefail

# --- Canonical list of blueprint-managed files ---
# This is the SINGLE SOURCE OF TRUTH for "which files does the blueprint
# own". The README.md and CLAUDE.md link here; do not duplicate the list
# elsewhere.
#
# Rules for what belongs in this list:
#   - Generic to every struct2flow project (no {{PROJECT_NAME}} after
#     bootstrap substitution → the file's content is the same everywhere).
#   - Improving it in one project should benefit every project (that's
#     what blueprint sync is for).
#
# What does NOT belong (project-owned, never synced):
#   - project_config_*.md  (the whole point of these files is project drift)
#   - AGENT_SIGNAL.md, HANDOVER.md, BUGS.md, BACKLOG.md, PLAN-*.md, etc.
#   - .githooks/pre-push-project  (project guards)
#   - backend/, frontend/, infra/, src/, anywhere with project code
#   - .claude/settings.local.json (host-specific)

MANAGED_FILES=(
  # Top-level agent protocol
  "CLAUDE.md"
  "AGENTS.md"
  "AGENT_ROSTER.md"
  "STACK_DEFAULTS.md"
  "Brewfile"

  # docs/ — the canonical reference docs
  "docs/DoD.md"
  "docs/OBSERVABILITY.md"
  "docs/SECURITY.md"
  "docs/INFRASTRUCTURE.md"
  "docs/DOCUMENTATION.md"
  "docs/A2BP_PLAYBOOK.md"
  "docs/PUBLISHING.md"
  "docs/way-of-working.md"

  # scripts/ — the agent infra
  "scripts/codex-signal-watch.sh"
  "scripts/start-codex-signal-watch.sh"
  "scripts/start-gemini-signal-watch.sh"
  "scripts/start-copilot-signal-watch.sh"
  "scripts/start-all-watchers.sh"
  "scripts/agent-activity.sh"
  "scripts/team-kickoff.sh"
  "scripts/new-project.sh"
  "scripts/blueprint"
  "scripts/build-deck.sh"
  "scripts/sonar.sh"
  "scripts/sonar-api.sh"

  # .githooks/ — generic gate
  ".githooks/pre-push"
  ".githooks/pre-push-project.example"

  # gitleaks generic false-positive allowlist (working-tree scans only;
  # staged-scan gate runs the full default rule set)
  ".gitleaks.toml"

  # .claude/ — generic permission allowlist (host-specific bits live in
  # .claude/settings.local.json which is gitignored)
  ".claude/settings.json"

  # Folder skeleton READMEs — describe the conventions, never project content
  "docs/backlog/README.md"
  "docs/doing/README.md"
  "docs/waiting-acceptance/README.md"
  "docs/done/README.md"
  "docs/config/README.md"
  "docs/mocks/README.md"
  "docs/requirements/README.md"
  "config/README.md"
)

# Files that are BOOTSTRAPPED from the blueprint as templates but then
# project-owned. New projects get them via new-project.sh; they're NOT
# synced afterward (improvements to the template propagate to *new*
# projects only).
TEMPLATE_FILES=(
  "project_config_overview.md"
  "project_config_paths.md"
  "project_config_dod.md"
  "project_config_security.md"
  "project_config_infra.md"
  "sonar-project.properties"
)

# --- ANSI ---
if [ -t 1 ]; then
  C_RED=$'\033[31m'
  C_GREEN=$'\033[32m'
  C_YELLOW=$'\033[33m'
  C_BLUE=$'\033[34m'
  C_BOLD=$'\033[1m'
  C_DIM=$'\033[2m'
  C_RESET=$'\033[0m'
else
  C_RED=""; C_GREEN=""; C_YELLOW=""; C_BLUE=""; C_BOLD=""; C_DIM=""; C_RESET=""
fi

# --- Helpers ---
die() {
  echo "${C_RED}error:${C_RESET} $*" >&2
  exit 1
}

# --- Marker pattern ---
# Blueprint-managed regions in a project file are bounded by lines
# matching BLUEPRINT:BEGIN / BLUEPRINT:END. The marker text is just a
# substring — the surrounding comment syntax (HTML, shell, JS) is up to
# the file's language. Pull behavior:
#
#   - Both files have matched markers → marker-aware merge: project's
#     outside-marker content is preserved byte-identical; only the
#     inside-marker regions are replaced with blueprint's.
#   - Neither file has markers → legacy whole-file copy.
#   - Asymmetric (one has markers, the other doesn't) → fall back to
#     whole-file copy with a `.bp-bak` backup of the project file and
#     a loud warning. Project owner reconciles.
#   - Marker structure mismatch (different region count, unbalanced
#     BEGIN/END) → fall back to whole-file copy with `.bp-bak` and a
#     warning.

# marker_aware_merge BP_FILE PROJ_FILE OUT_FILE
# Returns 0 on success, 1 on structural mismatch.
marker_aware_merge() {
  local bp_file="$1"
  local proj_file="$2"
  local out_file="$3"

  local bp_begin proj_begin bp_end proj_end
  bp_begin=$(grep -c 'BLUEPRINT:BEGIN' "$bp_file" 2>/dev/null || true)
  bp_end=$(grep -c 'BLUEPRINT:END' "$bp_file" 2>/dev/null || true)
  proj_begin=$(grep -c 'BLUEPRINT:BEGIN' "$proj_file" 2>/dev/null || true)
  proj_end=$(grep -c 'BLUEPRINT:END' "$proj_file" 2>/dev/null || true)

  [ -z "$bp_begin" ] && bp_begin=0
  [ -z "$bp_end" ] && bp_end=0
  [ -z "$proj_begin" ] && proj_begin=0
  [ -z "$proj_end" ] && proj_end=0

  if [ "$bp_begin" -ne "$bp_end" ] || [ "$proj_begin" -ne "$proj_end" ] || [ "$bp_begin" -ne "$proj_begin" ]; then
    return 1
  fi

  awk -v bp_file="$bp_file" '
    function read_bp_inside_regions(   line, region_idx, capture) {
      region_idx = 0
      capture = 0
      while ((getline line < bp_file) > 0) {
        if (line ~ /BLUEPRINT:BEGIN/) {
          capture = 1
          region_idx++
          bp_inside[region_idx] = ""
          continue
        }
        if (line ~ /BLUEPRINT:END/) {
          capture = 0
          continue
        }
        if (capture) {
          bp_inside[region_idx] = bp_inside[region_idx] line "\n"
        }
      }
      close(bp_file)
      bp_n_regions = region_idx
    }
    BEGIN { read_bp_inside_regions() ; cur_region = 0 ; in_inside = 0 }
    /BLUEPRINT:BEGIN/ {
      print
      cur_region++
      printf "%s", bp_inside[cur_region]
      in_inside = 1
      next
    }
    /BLUEPRINT:END/ {
      print
      in_inside = 0
      next
    }
    in_inside { next }
    { print }
  ' "$proj_file" > "$out_file"
}

# pull_file BP_FILE PROJ_FILE
# Decides between marker-aware merge and whole-file copy. Backs up the
# project file as PROJ_FILE.bp-bak when falling back due to a marker
# mismatch (so the project owner can recover the local content).
# Substitute the blueprint template placeholders with the project's
# name. The blueprint stores template tokens like `{{PROJECT_NAME}}`
# / `{{PROJECT_NAME_UPPER}}` so the same managed file can serve every
# project. `new-project.sh` runs this on bootstrap; this function
# repeats it after each `pull` so a pulled file lands as a real,
# usable file instead of leaking the literal placeholder. The project
# name is the basename of the project root.
_should_substitute() {
  # Skip files that legitimately document or implement the substitution
  # itself. The placeholder tokens appear in their source as code/docs,
  # NOT as template tokens — substituting would corrupt the tool.
  case "$1" in
    *scripts/blueprint|*scripts/new-project.sh) return 1 ;;
  esac
  return 0
}

# Write a placeholder-substituted COPY of the blueprint file to a
# temp path and print the temp path. Used by drift comparison +
# pull's "same?" check so the templated blueprint side is compared
# against the substituted project side instead of producing infinite
# false drift.
substituted_blueprint_copy() {
  local bp="$1"
  if ! _should_substitute "$bp"; then
    echo "$bp"
    return 0
  fi
  local proj_name
  proj_name=$(basename "$(pwd)")
  local proj_upper
  proj_upper=$(echo "$proj_name" | tr 'a-z-' 'A-Z_')
  local tmp
  tmp=$(mktemp)
  sed \
    -e "s/{{PROJECT_NAME_UPPER}}/${proj_upper}/g" \
    -e "s/{{PROJECT_NAME}}/${proj_name}/g" \
    "$bp" > "$tmp"
  echo "$tmp"
}

# Substitute placeholders in a file in-place. Called after every pull
# `cp` so the project file lands as a real, usable file instead of
# leaking the literal `{{PROJECT_NAME}}` token.
substitute_placeholders() {
  local f="$1"
  if ! _should_substitute "$f"; then return 0; fi
  local proj_name
  proj_name=$(basename "$(pwd)")
  local proj_upper
  proj_upper=$(echo "$proj_name" | tr 'a-z-' 'A-Z_')
  if grep -q '{{PROJECT_NAME' "$f" 2>/dev/null; then
    local tmp
    tmp=$(mktemp)
    sed \
      -e "s/{{PROJECT_NAME_UPPER}}/${proj_upper}/g" \
      -e "s/{{PROJECT_NAME}}/${proj_name}/g" \
      "$f" > "$tmp" && mv "$tmp" "$f"
  fi
}

pull_file() {
  local bp="$1"
  local f="$2"

  # New file in project → whole-file copy (no merging possible).
  if [ ! -f "$f" ]; then
    cp "$bp" "$f"
    substitute_placeholders "$f"
    return 0
  fi

  local bp_has=0 proj_has=0
  grep -q 'BLUEPRINT:BEGIN' "$bp" 2>/dev/null && bp_has=1
  grep -q 'BLUEPRINT:BEGIN' "$f"  2>/dev/null && proj_has=1

  if [ "$bp_has" -eq 1 ] && [ "$proj_has" -eq 1 ]; then
    local tmp
    tmp=$(mktemp)
    if marker_aware_merge "$bp" "$f" "$tmp"; then
      mv "$tmp" "$f"
      substitute_placeholders "$f"
      echo "  ${C_DIM}    (marker-aware merge: project outside-marker content preserved)${C_RESET}"
      return 0
    else
      rm -f "$tmp"
      echo "  ${C_YELLOW}    warn: marker structure mismatch — backing up + whole-file copy${C_RESET}"
      cp "$f" "$f.bp-bak"
      cp "$bp" "$f"
      substitute_placeholders "$f"
      echo "  ${C_DIM}    backup at $f.bp-bak — reconcile manually${C_RESET}"
      return 0
    fi
  fi

  if [ "$bp_has" -eq 1 ] && [ "$proj_has" -eq 0 ]; then
    echo "  ${C_YELLOW}    warn: blueprint uses markers, project doesn't — backing up + whole-file copy${C_RESET}"
    cp "$f" "$f.bp-bak"
    cp "$bp" "$f"
    substitute_placeholders "$f"
    echo "  ${C_DIM}    backup at $f.bp-bak — add markers in the project to preserve content next pull${C_RESET}"
    return 0
  fi

  if [ "$bp_has" -eq 0 ] && [ "$proj_has" -eq 1 ]; then
    echo "  ${C_RED}    refuse: project has markers but blueprint doesn't — pull would strip them${C_RESET}"
    echo "  ${C_DIM}    either the blueprint version is stale (run a2bp from another project),${C_RESET}"
    echo "  ${C_DIM}    or remove markers locally if they're no longer wanted. Skipping this file.${C_RESET}"
    return 1
  fi

  # Neither has markers — legacy whole-file copy.
  cp "$bp" "$f"
  substitute_placeholders "$f"
}

read_blueprint_source() {
  if [ ! -f .blueprint-source ]; then
    die "no .blueprint-source in $(pwd) — not a struct2flow project (run from project root)"
  fi
  BLUEPRINT_ROOT=$(grep '^blueprint_source' .blueprint-source | cut -d= -f2- | xargs)
  BOOTSTRAP_SHA=$(grep '^bootstrap_sha' .blueprint-source | cut -d= -f2- | xargs)
  BOOTSTRAP_DATE=$(grep '^bootstrap_date' .blueprint-source | cut -d= -f2- | xargs)
  if [ -z "$BLUEPRINT_ROOT" ] || [ ! -d "$BLUEPRINT_ROOT" ]; then
    die ".blueprint-source points at '$BLUEPRINT_ROOT' which does not exist"
  fi
}

# --- Subcommand: files ---
cmd_files() {
  echo "${C_BOLD}Blueprint-managed files (synced by 'blueprint pull'):${C_RESET}"
  for f in "${MANAGED_FILES[@]}"; do
    echo "  $f"
  done
  echo
  echo "${C_BOLD}Template files (seeded once at bootstrap, then project-owned):${C_RESET}"
  for f in "${TEMPLATE_FILES[@]}"; do
    echo "  $f"
  done
  echo
  echo "${C_DIM}Source of truth: scripts/blueprint MANAGED_FILES array.${C_RESET}"
}

# --- Subcommand: drift ---
cmd_drift() {
  read_blueprint_source

  echo "${C_BOLD}Blueprint drift check${C_RESET}"
  echo "  project:    $(pwd)"
  echo "  blueprint:  $BLUEPRINT_ROOT"
  echo "  bootstrap:  $BOOTSTRAP_SHA ($BOOTSTRAP_DATE)"

  CURRENT_SHA=$(git -C "$BLUEPRINT_ROOT" rev-parse HEAD 2>/dev/null || echo "no-sha")
  echo "  blueprint HEAD: $CURRENT_SHA"
  echo

  if [ "$CURRENT_SHA" != "$BOOTSTRAP_SHA" ] && [ "$BOOTSTRAP_SHA" != "no-sha" ]; then
    AHEAD_COUNT=$(git -C "$BLUEPRINT_ROOT" rev-list --count "$BOOTSTRAP_SHA..$CURRENT_SHA" 2>/dev/null || echo "?")
    echo "${C_BLUE}Blueprint has $AHEAD_COUNT commit(s) since this project was last synced:${C_RESET}"
    git -C "$BLUEPRINT_ROOT" log --oneline "$BOOTSTRAP_SHA..$CURRENT_SHA" 2>/dev/null | sed 's/^/  /'
    echo
  fi

  DRIFTED=()
  MISSING_BLUEPRINT=()
  MISSING_PROJECT=()

  for f in "${MANAGED_FILES[@]}"; do
    bp="$BLUEPRINT_ROOT/$f"
    if [ ! -f "$bp" ]; then
      MISSING_BLUEPRINT+=("$f")
      continue
    fi
    if [ ! -f "$f" ]; then
      MISSING_PROJECT+=("$f")
      continue
    fi
    # Substitute placeholders on the blueprint side before comparing,
    # otherwise every templated file looks "drifted" forever after
    # the first substitute-on-pull.
    local bp_cmp
    bp_cmp=$(substituted_blueprint_copy "$bp")
    if ! diff -q "$bp_cmp" "$f" >/dev/null 2>&1; then
      DRIFTED+=("$f")
    fi
    [ "$bp_cmp" != "$bp" ] && rm -f "$bp_cmp"
  done

  if [ ${#DRIFTED[@]} -eq 0 ] && [ ${#MISSING_BLUEPRINT[@]} -eq 0 ] && [ ${#MISSING_PROJECT[@]} -eq 0 ]; then
    echo "${C_GREEN}✓ All blueprint-managed files match the blueprint HEAD.${C_RESET}"
    return 0
  fi

  if [ ${#DRIFTED[@]} -gt 0 ]; then
    echo "${C_YELLOW}Drifted (project ≠ blueprint HEAD): ${#DRIFTED[@]}${C_RESET}"
    for f in "${DRIFTED[@]}"; do echo "  ${C_YELLOW}~${C_RESET} $f"; done
    echo
  fi
  if [ ${#MISSING_PROJECT[@]} -gt 0 ]; then
    echo "${C_BLUE}New in blueprint (not in this project): ${#MISSING_PROJECT[@]}${C_RESET}"
    for f in "${MISSING_PROJECT[@]}"; do echo "  ${C_BLUE}+${C_RESET} $f"; done
    echo
  fi
  if [ ${#MISSING_BLUEPRINT[@]} -gt 0 ]; then
    echo "${C_RED}Listed managed but missing in blueprint: ${#MISSING_BLUEPRINT[@]}${C_RESET}"
    for f in "${MISSING_BLUEPRINT[@]}"; do echo "  ${C_RED}!${C_RESET} $f"; done
    echo "${C_DIM}  (the MANAGED_FILES array in scripts/blueprint may be ahead of the blueprint itself)${C_RESET}"
    echo
  fi

  echo "Next:"
  echo "  ${C_DIM}blueprint pull${C_RESET}             # pull all drifted + new forward"
  echo "  ${C_DIM}blueprint pull <file>${C_RESET}      # pull one file"
  echo "  ${C_DIM}blueprint pull <file> --yes${C_RESET}  # skip the per-file prompt"
}

# --- Subcommand: pull ---
cmd_pull() {
  read_blueprint_source

  local auto_yes=0
  local files=()
  for arg in "$@"; do
    case "$arg" in
      --yes|-y) auto_yes=1 ;;
      -*) die "unknown option: $arg" ;;
      *) files+=("$arg") ;;
    esac
  done

  # Default: every drifted or missing file
  if [ ${#files[@]} -eq 0 ]; then
    for f in "${MANAGED_FILES[@]}"; do
      bp="$BLUEPRINT_ROOT/$f"
      if [ ! -f "$bp" ]; then continue; fi
      if [ ! -f "$f" ]; then
        files+=("$f")
        continue
      fi
      local bp_cmp
      bp_cmp=$(substituted_blueprint_copy "$bp")
      if ! diff -q "$bp_cmp" "$f" >/dev/null 2>&1; then
        files+=("$f")
      fi
      [ "$bp_cmp" != "$bp" ] && rm -f "$bp_cmp"
    done
  fi

  if [ ${#files[@]} -eq 0 ]; then
    echo "${C_GREEN}✓ Nothing to pull. Project matches blueprint HEAD.${C_RESET}"
    return 0
  fi

  echo "${C_BOLD}Pulling from $BLUEPRINT_ROOT${C_RESET}"
  local pulled=0
  for f in "${files[@]}"; do
    bp="$BLUEPRINT_ROOT/$f"
    if [ ! -f "$bp" ]; then
      echo "  ${C_RED}skip${C_RESET}  $f  (not in blueprint)"
      continue
    fi
    # Compare against the substituted blueprint copy so templated
    # files that have already been substituted in the project don't
    # show as "different" forever.
    local bp_cmp_pull
    bp_cmp_pull=$(substituted_blueprint_copy "$bp")
    if [ -f "$f" ] && diff -q "$bp_cmp_pull" "$f" >/dev/null 2>&1; then
      [ "$bp_cmp_pull" != "$bp" ] && rm -f "$bp_cmp_pull"
      echo "  ${C_DIM}same${C_RESET}  $f"
      continue
    fi
    echo
    echo "${C_BOLD}── $f${C_RESET}"
    if [ ! -f "$f" ]; then
      echo "  ${C_BLUE}new file${C_RESET} (blueprint adds it; project doesn't have it yet)"
    else
      # Diff against the substituted blueprint copy so the user sees
      # what would actually land in their tree, not noise from the
      # placeholder tokens.
      diff -u "$f" "$bp_cmp_pull" | head -60 || true
      echo "  ${C_DIM}(diff truncated at 60 lines — open the file to see all)${C_RESET}"
    fi
    [ "$bp_cmp_pull" != "$bp" ] && rm -f "$bp_cmp_pull"
    if [ "$auto_yes" -eq 0 ]; then
      printf "  Pull this file? [y/N/q] "
      read -r ans </dev/tty
      case "$ans" in
        y|Y) ;;
        q|Q) echo "  ${C_YELLOW}aborted${C_RESET}"; break ;;
        *) echo "  ${C_DIM}skipped${C_RESET}"; continue ;;
      esac
    fi
    mkdir -p "$(dirname "$f")"
    if pull_file "$bp" "$f"; then
      echo "  ${C_GREEN}pulled${C_RESET} $f"
      pulled=$((pulled+1))
    else
      echo "  ${C_RED}skipped${C_RESET} $f (see warning above)"
    fi
  done

  echo
  if [ $pulled -gt 0 ]; then
    CURRENT_SHA=$(git -C "$BLUEPRINT_ROOT" rev-parse HEAD 2>/dev/null || echo "no-sha")
    if [ -f .blueprint-source ] && [ "$CURRENT_SHA" != "no-sha" ]; then
      # Update bootstrap_sha to blueprint HEAD
      sed -i.bak "s/^bootstrap_sha.*=.*/bootstrap_sha    = $CURRENT_SHA/" .blueprint-source
      rm -f .blueprint-source.bak
      echo "Updated .blueprint-source bootstrap_sha → $CURRENT_SHA"
    fi
    echo "${C_GREEN}✓ Pulled $pulled file(s). Review with 'git diff' and commit.${C_RESET}"
  else
    echo "${C_DIM}Nothing pulled.${C_RESET}"
  fi
}

# --- Subcommand: a2bp ---
cmd_a2bp() {
  read_blueprint_source
  if [ "$#" -eq 0 ]; then
    die "usage: blueprint a2bp FILE [FILE...]"
  fi

  echo "${C_BOLD}Apply-to-blueprint${C_RESET}"
  echo "  project:    $(pwd)"
  echo "  blueprint:  $BLUEPRINT_ROOT"
  echo

  local copied=0
  local copied_files=()
  for f in "$@"; do
    # Validate that this file is blueprint-managed
    local is_managed=0
    for m in "${MANAGED_FILES[@]}"; do
      if [ "$m" = "$f" ]; then is_managed=1; break; fi
    done
    if [ "$is_managed" -eq 0 ]; then
      echo "  ${C_RED}reject${C_RESET}  $f"
      echo "    ${C_DIM}not in the blueprint-managed list — see 'blueprint files'.${C_RESET}"
      echo "    ${C_DIM}If this file SHOULD be blueprint-managed, add it to the MANAGED_FILES${C_RESET}"
      echo "    ${C_DIM}array in scripts/blueprint first.${C_RESET}"
      continue
    fi
    if [ ! -f "$f" ]; then
      echo "  ${C_RED}skip${C_RESET}    $f  (not present in project)"
      continue
    fi
    local bp="$BLUEPRINT_ROOT/$f"
    if [ -f "$bp" ] && diff -q "$f" "$bp" >/dev/null 2>&1; then
      echo "  ${C_DIM}same${C_RESET}    $f  (project version already matches blueprint)"
      continue
    fi
    mkdir -p "$(dirname "$bp")"
    cp "$f" "$bp"
    echo "  ${C_GREEN}copied${C_RESET}  $f → blueprint"
    copied=$((copied+1))
    copied_files+=("$f")
  done

  echo
  if [ $copied -eq 0 ]; then
    echo "${C_DIM}Nothing copied.${C_RESET}"
    return 0
  fi

  echo "${C_GREEN}✓ Copied $copied file(s) into the blueprint working tree.${C_RESET}"
  echo

  # --- Strong "no context switch" header ---
  echo "${C_BOLD}━━━ Back-propagation is NOT complete. ━━━${C_RESET}"
  echo "${C_BOLD}Walk this from the CURRENT session (no new prompt in the blueprint repo):${C_RESET}"
  echo "${C_DIM}  $BLUEPRINT_ROOT/docs/A2BP_PLAYBOOK.md${C_RESET}"
  echo "${C_DIM}  The four §6.4 violations of the last week were all caused by deferring${C_RESET}"
  echo "${C_DIM}  the doc-sync ripples to a 'next session in the blueprint'. Don't.${C_RESET}"
  echo

  # --- Per-file ripple hints (class-based; matches A2BP_PLAYBOOK.md Step A) ---
  echo "${C_BOLD}Step A — Ripples to check (per file you just copied):${C_RESET}"
  local touched_deck=0
  local touched_recipe=0
  local touched_principle=0
  local touched_agent=0
  local touched_sync=0
  local touched_stack=0
  local touched_gate=0
  local touched_prepush=0
  for f in "${copied_files[@]}"; do
    case "$f" in
      CLAUDE.md)
        echo "  ${C_YELLOW}~${C_RESET} ${C_BOLD}$f${C_RESET}"
        echo "      → Class A (Principle) or F (Agent layer) — also check:"
        echo "        • docs/way-of-working.md intro slide + concern slides for any concern touched"
        echo "        • the concern's recipe doc (OBSERVABILITY/SECURITY/INFRASTRUCTURE/DOCUMENTATION/etc.)"
        echo "        • README.md hero concern table"
        echo "        • CLAUDE.md §\"docs/way-of-working.md is the canonical pitch surface\" mirror list (10 items)"
        touched_principle=1
        touched_deck=1
        ;;
      docs/OBSERVABILITY.md|docs/SECURITY.md|docs/INFRASTRUCTURE.md|docs/DOCUMENTATION.md)
        local concern
        concern=$(basename "$f" .md)
        echo "  ${C_YELLOW}~${C_RESET} ${C_BOLD}$f${C_RESET}"
        echo "      → Class B (Recipe) — also check:"
        echo "        • docs/way-of-working.md '<concern> — recipes per stack' slide"
        echo "        • project_config_overview.md §\"$(echo $concern | tr A-Z a-z) stack\" if a new mechanism row was implied"
        touched_recipe=1
        touched_deck=1
        ;;
      docs/DoD.md)
        echo "  ${C_YELLOW}~${C_RESET} ${C_BOLD}$f${C_RESET}"
        echo "      → Class C (Gate) — also check:"
        echo "        • docs/way-of-working.md Quality slides if §3 or §4 changed"
        echo "        • project_config_dod.md if a new table row was implied"
        echo "        • DoD §7 handoff checklist for cross-references"
        touched_gate=1
        ;;
      .githooks/pre-push|Brewfile)
        echo "  ${C_YELLOW}~${C_RESET} ${C_BOLD}$f${C_RESET}"
        echo "      → Class D (Pre-push) — also check:"
        echo "        • docs/DoD.md §4 (pre-push gate description)"
        echo "        • CLAUDE.md §\"Before Every Push\""
        echo "        • README.md \"What's in the blueprint\" tree if file list changed"
        echo "        • project_config_dod.md §\"Pre-push gate — project commands\" table"
        touched_prepush=1
        ;;
      scripts/blueprint|scripts/new-project.sh)
        echo "  ${C_YELLOW}~${C_RESET} ${C_BOLD}$f${C_RESET}"
        echo "      → Class E (Sync layer) — also check:"
        echo "        • README.md §\"The sync model\""
        echo "        • CLAUDE.md §\"Blueprint sync\""
        echo "        • docs/A2BP_PLAYBOOK.md if the calling pattern changed"
        touched_sync=1
        ;;
      AGENTS.md|AGENT_ROSTER.md|scripts/agent-activity.sh|scripts/start-codex-signal-watch.sh|scripts/start-gemini-signal-watch.sh)
        echo "  ${C_YELLOW}~${C_RESET} ${C_BOLD}$f${C_RESET}"
        echo "      → Class F (Agent layer) — also check:"
        echo "        • docs/way-of-working.md 'persona team — radio-over' slide"
        echo "        • CLAUDE.md §\"docs/way-of-working.md is the canonical pitch surface\" item #9"
        echo "        • README.md hero paragraph if framing changed"
        touched_agent=1
        touched_deck=1
        ;;
      STACK_DEFAULTS.md)
        echo "  ${C_YELLOW}~${C_RESET} ${C_BOLD}$f${C_RESET}"
        echo "      → Class G (Stack default) — also check:"
        echo "        • docs/way-of-working.md Architecture slide (slide 1 of the concern block)"
        echo "        • CLAUDE.md §\"Architecture Principles\""
        touched_stack=1
        touched_deck=1
        ;;
      docs/way-of-working.md)
        echo "  ${C_YELLOW}~${C_RESET} ${C_BOLD}$f${C_RESET}"
        echo "      → Deck source changed — REBUILD the PDF (see Step C below)"
        touched_deck=1
        ;;
      *)
        echo "  ${C_DIM}~${C_RESET} ${C_DIM}$f${C_RESET}  (Class H cosmetic / unclassified — no ripples assumed; verify in playbook §A)"
        ;;
    esac
  done

  # --- Step C — Deck dance reminder if anything touched the deck ---
  if [ "$touched_deck" -eq 1 ] || [ "$touched_principle" -eq 1 ]; then
    echo
    echo "${C_BOLD}Step C — Deck dance:${C_RESET}"
    echo "  1. Edit slide(s) in $BLUEPRINT_ROOT/docs/way-of-working.md"
    echo "  2. Sweep count words: ${C_DIM}grep -niE '\\bsix\\b|\\bseven\\b|\\beight\\b' $BLUEPRINT_ROOT/{docs/way-of-working.md,README.md}${C_RESET}"
    echo "  3. Rebuild PDF:        ${C_DIM}( cd $BLUEPRINT_ROOT && scripts/build-deck.sh )${C_RESET}"
    echo "  4. Visual-check the changed slides (PNG render + Read tool)"
    echo "  5. Stage the .md source AND the .pdf together"
  fi

  # --- Step D — Commit + push from the originating session ---
  echo
  echo "${C_BOLD}Step D — Commit + push (run from THIS session):${C_RESET}"
  echo "  ( cd $BLUEPRINT_ROOT &&"
  echo "    git checkout .claude/settings.json &&    ${C_DIM}# revert any auto-allowlist pollution${C_RESET}"
  echo "    git status &&"
  echo "    git add <every-file-touched-including-PDF> &&"
  echo "    git commit -m \"<conventional commit; list every ripple in the body>\" &&"
  echo "    git push origin main"
  echo "  )"

  # --- Step E — Verify ---
  echo
  echo "${C_BOLD}Step E — Verify drift closed:${C_RESET}"
  echo "  blueprint drift               ${C_DIM}# expect: '✓ All blueprint-managed files match the blueprint HEAD.'${C_RESET}"
  echo "  blueprint pull --yes          ${C_DIM}# if any ripple files now drift forward${C_RESET}"

  echo
  echo "${C_DIM}Full playbook: $BLUEPRINT_ROOT/docs/A2BP_PLAYBOOK.md${C_RESET}"
}

# --- Subcommand: help ---
cmd_help() {
  sed -n '2,28p' "$0" | sed 's/^# //; s/^#//'
}

# --- Dispatch ---
SUBCMD="${1:-help}"
shift || true
case "$SUBCMD" in
  drift)  cmd_drift "$@" ;;
  pull)   cmd_pull "$@" ;;
  a2bp|push) cmd_a2bp "$@" ;;
  files|list) cmd_files "$@" ;;
  help|--help|-h) cmd_help ;;
  *) die "unknown subcommand: $SUBCMD (try 'blueprint help')" ;;
esac
